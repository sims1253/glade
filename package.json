{
  "name": "glade",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "effect": "latest",
      "@effect/platform-node": "latest",
      "@effect/sql-sqlite-bun": "latest",
      "@effect/language-service": "latest",
      "@effect/vitest": "latest",
      "@types/bun": "latest",
      "@types/node": "latest",
      "tsdown": "latest",
      "typescript": "latest",
      "vitest": "latest"
    }
  },
  "scripts": {
    "dev": "node ./scripts/dev-runner.mjs",
    "dev:hosted": "node ./scripts/hosted-dev-runner.mjs",
    "dev:web": "turbo run dev --filter=@glade/web",
    "dev:server": "turbo run dev --filter=@glade/server",
    "dev:desktop": "turbo run dev --filter=@glade/desktop",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test smoke-test",
    "lint": "oxlint . --deny-warnings",
    "clean": "rm -rf node_modules bun.lock .turbo apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist"
  },
  "devDependencies": {
    "oxlint": "latest",
    "turbo": "latest"
  }
}
