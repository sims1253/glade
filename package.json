{
  "name": "glade",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "3.19.19",
      "@effect/platform-node": "0.104.1",
      "@effect/sql-sqlite-bun": "0.50.2",
      "@effect/language-service": "0.79.0",
      "@types/bun": "1.3.10",
      "@types/node": "25.3.5",
      "tsdown": "0.21.1",
      "typescript": "5.9.3",
      "vitest": "4.0.18"
    }
  },
  "scripts": {
    "dev": "node ./scripts/dev-runner.ts",
    "dev:hosted": "node ./scripts/hosted-dev-runner.ts",
    "dev:web": "turbo run dev --filter=@glade/web",
    "dev:server": "turbo run dev --filter=@glade/server",
    "dev:desktop": "turbo run dev --filter=@glade/desktop",
    "build": "turbo run build",
    "build:desktop-bundle": "node ./scripts/build-desktop-bundle.ts",
    "build:server:standalone": "node ./scripts/build-standalone-server.ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test smoke-test",
    "lint": "oxlint . --deny-warnings",
    "clean": "rm -rf node_modules bun.lock .turbo apps/*/node_modules packages/*/node_modules scripts/node_modules apps/*/dist apps/*/dist-electron packages/*/dist"
  },
  "devDependencies": {
    "oxlint": "1.51.0",
    "turbo": "2.8.14"
  },
  "engines": {
    "bun": "^1.3.10",
    "node": "^25.6.1"
  }
}
