{
  "name": "@glade/shared",
  "version": "0.13.1",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    },
    "./logging": {
      "types": "./src/logging.ts",
      "import": "./src/logging.ts",
      "require": "./dist/logging.cjs"
    },
    "./Net": {
      "types": "./src/Net.ts",
      "import": "./src/Net.ts",
      "require": "./dist/Net.cjs"
    },
    "./process": {
      "types": "./src/process.ts",
      "import": "./src/process.ts",
      "require": "./dist/process.cjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
