{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["@effect/platform-node"],
        "includeSuggestionsInTsc": false,
        "ignoreEffectWarningsInTscExitCode": true,
        "diagnosticSeverity": {
          "importFromBarrel": "off",
          "preferSchemaOverJson": "off",
          "globalErrorInEffectFailure": "off",
          "globalErrorInEffectCatch": "off",
          "runEffectInsideEffect": "off",
          "unnecessaryFailYieldableError": "off",
          "scopeInLayerEffect": "off"
        }
      }
    ]
  },
  "include": ["src"]
}
