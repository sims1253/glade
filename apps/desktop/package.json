{
  "name": "@glade/desktop",
  "version": "0.11.7",
  "description": "Glade desktop shell",
  "author": "sims1253",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun run --parallel dev:bundle dev:electron",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node ./scripts/dev-electron.ts",
    "build": "tsdown",
    "start": "electron ./dist-electron/main.cjs",
    "bundle": "node ../../scripts/build-desktop-bundle.ts",
    "dist": "node ../../scripts/build-desktop-bundle.ts && node ../../scripts/run-electron-builder.ts --config electron-builder.yml",
    "dist:dir": "node ../../scripts/build-desktop-bundle.ts && node ../../scripts/run-electron-builder.ts --dir --config electron-builder.yml",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke-test": "node ./scripts/smoke-test.mjs",
    "smoke-test:repl-detach": "node ./scripts/smoke-test.mjs repl-detach",
    "smoke-test:bayesgrove": "node ./scripts/real-bayesgrove-smoke.mjs"
  },
  "dependencies": {
    "@glade/shared": "workspace:*",
    "effect": "catalog:",
    "electron-updater": "6.8.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "40.8.0",
    "electron-builder": "26.8.2",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "productName": "Glade"
}
